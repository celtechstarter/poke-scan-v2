# Google Gemini API Key (primaeres Vision-Backend, kostenlos via aistudio.google.com)
GEMINI_API_KEY=xxx

# NVIDIA NIM API Key (Fallback Vision-Backend, Serverless Functions - ohne VITE_ prefix)
NVIDIA_API_KEY=nvapi-xxx

# Supabase (lokal: .env.local, Vercel: Environment Variables)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
